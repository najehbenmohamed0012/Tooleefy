# Tooleefy Hostinger & cPanel Deployment Configuration
# ---------------------------------------------------

# Enable Phusion Passenger to run the Node.js application
<IfModule mod_passenger.c>
    PassengerEnabled on
    PassengerAppType node
    PassengerStartupFile index.js
    PassengerBaseURI /
</IfModule>

# Handle URL Rewriting and Route Delegations
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # 1. Force HTTPS redirect (essential for security and SEO)
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # 2. Static File Performance Optimization:
    # If the requested asset exists inside the dist/ build folder,
    # let Apache serve it directly to bypass Node.js entirely.
    # This prevents triggering Hostinger's concurrent connection limits (Entry Processes).
    RewriteCond %{DOCUMENT_ROOT}/dist%{REQUEST_URI} -f
    RewriteRule ^(.*)$ /dist/$1 [L]

    # 3. Dynamic Routes & SPA Routing Fallback:
    # Rewrite all virtual paths (not physical files or folders, and not starting with /api)
    # to the root / with a query parameter preserving the original route path.
    # This prevents Passenger from searching for a startup file in subdirectories (causing 503)
    # while allowing our server to inspect the _route_ query parameter to inject correct SEO tags!
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/api
    RewriteRule ^(.*)$ /?_route_=$1 [QSA,L]
</IfModule>
