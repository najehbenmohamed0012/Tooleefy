# Tooleefy Hostinger & cPanel Deployment Configuration
# ---------------------------------------------------

# Enable Phusion Passenger to run the Node.js application
<IfModule mod_passenger.c>
    PassengerEnabled on
    PassengerAppType node
    PassengerStartupFile index.js
    PassengerBaseURI /
</IfModule>

# Handle URL Rewriting and Route Delegations
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # 1. Force HTTPS redirect (essential for security and SEO)
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # 2. Static File Performance Optimization:
    # Let Apache serve critical static assets directly from dist/ to bypass Node.js entirely.
    RewriteRule ^(assets/.*)$ dist/$1 [L]
    RewriteRule ^(images/.*)$ dist/$1 [L]
    RewriteRule ^(favicon\.svg|favicon\.ico|robots\.txt|sitemap\.xml|llms\.txt)$ dist/$1 [L]

    # 3. Explicit Virtual-to-Physical Route Mapping (Zero-dependency, avoids %{DOCUMENT_ROOT} bugs)
    # Direct mappings for all pre-rendered paths ensure Apache/LiteSpeed serves them natively
    # as physical index.html files, preserving query parameters (such as Twitter tracking tokens) perfectly.

    # Main Landing Page
    RewriteRule ^$ dist/index.html [L]

    # Specific Productivity Tools
    RewriteRule ^tools/(invoice|qr|barcode|converter)/?$ dist/tools/$1/index.html [L]

    # General Static Information Pages
    RewriteRule ^(categories|blog|about|faq|contact|value-our-tools|privacy|terms|cookies)/?$ dist/$1/index.html [L]

    # Blog Articles Deep Links
    RewriteRule ^blog/([^/]+)/?$ dist/blog/$1/index.html [L]

    # Private User Profiles and Auth States
    RewriteRule ^(dashboard|admin|settings/account|settings/preferences|login|register)/?$ dist/$1/index.html [L]

    # 4. Dynamic API Routing & SPA Fallback
    # Fallback unmatched virtual routes (such as API paths or virtual dynamics) to our Express entrypoint
    RewriteRule ^index\.js$ - [L]
    RewriteCond %{REQUEST_URI} !/api/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.js?_route_=$1 [QSA,L]
</IfModule>
