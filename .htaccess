# Tooleefy Hostinger & cPanel Deployment Configuration
# ---------------------------------------------------

# Enable Phusion Passenger to run the Node.js application
<IfModule mod_passenger.c>
    PassengerEnabled on
    PassengerAppType node
    PassengerStartupFile index.js
    PassengerBaseURI /
</IfModule>

# Handle URL Rewriting and Route Delegations
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # 1. Force HTTPS redirect (essential for security and SEO)
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # 2. Static File Performance Optimization:
    # If the requested asset exists inside the dist/ build folder,
    # let Apache serve it directly to bypass Node.js entirely.
    # This prevents triggering Hostinger's concurrent connection limits (Entry Processes).
    # We include both a direct relative path mapping and specific static folders for LiteSpeed compatibility.
    RewriteRule ^(assets/.*)$ dist/$1 [L]
    RewriteRule ^(favicon\.svg|favicon\.ico|robots\.txt|sitemap\.xml|llms\.txt)$ dist/$1 [L]
    RewriteCond %{DOCUMENT_ROOT}/dist%{REQUEST_URI} -f
    RewriteRule ^(.*)$ dist/$1 [L]

    # 3. Clean URL Virtual-to-Physical Route Mapping (SEO & Hostinger 404 Resolution)
    # If the user visits a path that has a pre-rendered folder inside dist/ containing index.html,
    # rewrite to that specific index.html directly. This allows Apache/Hostinger to serve the
    # correct page static files natively, enabling full multi-page indexing and zero refresh 404s.
    RewriteCond %{DOCUMENT_ROOT}/dist%{REQUEST_URI}/index.html -f
    RewriteRule ^(.*)$ dist/$1/index.html [L]

    RewriteCond %{DOCUMENT_ROOT}/dist%{REQUEST_URI}index.html -f
    RewriteRule ^(.*)$ dist/$1index.html [L]

    # 4. Dynamic Routes & SPA Routing Fallback:
    # Rewrite all virtual paths (not physical files or folders)
    # to the startup file index.js with a query parameter preserving the original route path.
    # On Hostinger and cPanel, removing the leading slash from index.js is critical 
    # to let Apache resolve the file relative to the current directory (avoiding 404s).
    RewriteRule ^index\.js$ - [L]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.js?_route_=$1 [QSA,L]
</IfModule>
